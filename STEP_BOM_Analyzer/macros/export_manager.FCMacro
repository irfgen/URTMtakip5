# -*- coding: utf-8 -*-
"""
STEP BOM Analyzer - Export Manager Macro
FreeCAD Native Macro for multi-format export

This macro handles:
- HTML report generation with embedded images
- Excel workbook creation with multiple sheets
- PDF report generation (if available)
- Multi-format export coordination
- Professional report templates
"""

import FreeCAD as App
import os
import json
import csv
from datetime import datetime
import sys

# Macro Information
__title__ = "STEP BOM Analyzer - Export Manager"
__author__ = "ÜRTM Takip Ekibi"
__version__ = "3.0.0"
__date__ = "2025-09-07"

def log_message(message, level="INFO"):
    """FreeCAD Console'a mesaj yaz"""
    timestamp = datetime.now().strftime("%H:%M:%S")
    formatted_msg = f"[{timestamp}] EXPORT_MANAGER - {level}: {message}"
    
    if level == "ERROR":
        App.Console.PrintError(formatted_msg + "\n")
    elif level == "WARNING": 
        App.Console.PrintWarning(formatted_msg + "\n")
    else:
        App.Console.PrintMessage(formatted_msg + "\n")

class HTMLReportGenerator:
    """HTML BOM raporu oluşturucu"""
    
    def __init__(self, bom_data, part_images=None):
        self.bom_data = bom_data
        self.part_images = part_images or {}
        
    def generate_html_template(self):
        """Modern HTML template oluştur"""
        html_template = """
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STEP BOM Analysis Report</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f5f5f5;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            background-color: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        
        .header {
            text-align: center;
            margin-bottom: 30px;
            padding: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 10px;
        }
        
        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        
        .metadata {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .metadata-card {
            background: #f8f9fa;
            padding: 20px;
